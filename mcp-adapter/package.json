{
  "name": "meridian-hr-mcp-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTML front-door MCP adapter for the Meridian HR sample \u2014 drives the server-rendered UI as a legacy app with no REST API (DioscHub integration demo).",
  "license": "MIT",
  "bin": {
    "meridian-hr-mcp": "dist/server.js",
    "meridian-hr-mcp-http": "dist/http-server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/http-server.js",
    "mcp": "node dist/server.js",
    "mcp:http": "node dist/http-server.js",
    "verify": "tsx scripts/verify.ts",
    "verify:hub": "tsx scripts/verify-hub.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cheerio": "^1.0.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
