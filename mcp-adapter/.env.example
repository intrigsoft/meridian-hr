# Meridian HR — MCP adapter (token broker)

# The Meridian app this adapter drives through its HTML front door.
MERIDIAN_BASE_URL=http://localhost:8080

# Port the Streamable HTTP server binds (what the hub connects to).
MERIDIAN_MCP_PORT=5175

# ── Hub bind (this adapter registers sessions with the hub) ──────────────────
# The hub URL and an admin capability key with the `auth:bind` scope
# (mint via the Dioschub admin portal — API keys → capability key).
DIOSC_HUB_URL=http://localhost:3333
DIOSC_HUB_API_KEY=

# ── Token issuing ────────────────────────────────────────────────────────────
# Secret for signing the HS256 session JWTs this adapter issues at bind time
# (blank = insecure dev fallback), and the shared secret the Meridian app must
# present on /auth/bind (must match the app's MERIDIAN_DIOSC_BIND_SECRET).
MCP_JWT_SECRET=
MCP_BIND_SECRET=

# ── Local stdio testing only (no per-call header) ────────────────────────────
# MERIDIAN_ARTIFACT=persona:priya.nair
# MERIDIAN_PERSONA=priya.nair
